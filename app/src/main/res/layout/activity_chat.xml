<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/primary"
    android:animateLayoutChanges="true"
    android:fitsSystemWindows="true">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/secondary"
        app:elevation="2dp"
        app:layout_constraintTop_toTopOf="parent">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize">

            <androidx.appcompat.widget.Toolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:navigationIcon="@drawable/ic_arrow_back"
                app:contentInsetStartWithNavigation="0dp">

                <LinearLayout
                    android:id="@+id/userInfoContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:paddingEnd="16dp">

                    <ImageView
                        android:id="@+id/ivChatAvatar"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_marginEnd="12dp"
                        android:src="@drawable/ic_profile_placeholder" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvChatUsername"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:text="Загрузка..."
                            android:maxLines="1"
                            android:ellipsize="end"/>

                        <TextView
                            android:id="@+id/tvChatStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp"
                            android:text="обновление..."
                            android:maxLines="1"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.appcompat.widget.Toolbar>

            <!-- ТУЛБАР ВЫДЕЛЕНИЯ -->
            <LinearLayout
                android:id="@+id/selectionToolbar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@color/primary"
                android:visibility="gone"
                android:elevation="8dp"
                android:paddingHorizontal="4dp">

                <ImageButton
                    android:id="@+id/btnCloseSelection"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@android:drawable/ic_menu_close_clear_cancel"
                    android:padding="12dp"
                    android:scaleType="fitCenter"
                    app:tint="@color/text_secondary"/>

                <TextView
                    android:id="@+id/tvSelectedCount"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginStart="12dp"
                    android:text="Выбрано: 1"/>

                <ImageButton
                    android:id="@+id/btnSelectionReact"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@android:drawable/ic_menu_add"
                    android:padding="10dp"
                    android:scaleType="fitCenter"
                    app:tint="@color/text_primary"/>

                <ImageButton
                    android:id="@+id/btnSelectionCopy"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@android:drawable/ic_menu_edit"
                    android:padding="10dp"
                    android:scaleType="fitCenter"
                    app:tint="@color/text_primary"/>

                <ImageButton
                    android:id="@+id/btnSelectionForward"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@android:drawable/ic_menu_revert"
                    android:padding="10dp"
                    android:scaleType="fitCenter"
                    app:tint="@color/text_primary"/>

                <ImageButton
                    android:id="@+id/btnSelectionDelete"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@android:drawable/ic_menu_delete"
                    android:padding="10dp"
                    android:scaleType="fitCenter"
                    app:tint="#FF3B30"/>
            </LinearLayout>
        </FrameLayout>

        <LinearLayout
            android:id="@+id/pinnedMessageContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@color/primary"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            android:visibility="gone"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground">

            <View
                android:layout_width="3dp"
                android:layout_height="match_parent"
                android:background="#3390EC"
                android:layout_marginEnd="8dp"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Закреплённое сообщение"
                    android:textColor="#3390EC"
                    android:textSize="12sp"
                    android:textStyle="bold"/>
                <TextView
                    android:id="@+id/tvPinnedText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:maxLines="1"
                    android:ellipsize="end"/>
            </LinearLayout>

            <ImageButton
                android:id="@+id/btnUnpin"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center_vertical"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                app:tint="@color/text_secondary"/>
        </LinearLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <!-- ГЛОБАЛЬНЫЙ ПЛЕЕР (ДИНАМИЧЕСКИЙ ОСТРОВ) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/globalPlayerContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="8dp"
        android:visibility="gone"
        app:cardCornerRadius="24dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="@color/primary"
        app:layout_constraintTop_toBottomOf="@id/appBarLayout">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:animateLayoutChanges="true"
            android:padding="12dp">

            <!-- КОМПАКТНЫЙ ВИД (Виден всегда) -->
            <ImageView
                android:id="@+id/gpIcon"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@android:drawable/ic_media_play"
                android:background="@drawable/circle_background"
                android:backgroundTint="#1A3390EC"
                app:tint="#3390EC"
                android:padding="8dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"/>

            <TextView
                android:id="@+id/gpTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Играет голосовое"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginStart="12dp"
                app:layout_constraintTop_toTopOf="@id/gpIcon"
                app:layout_constraintBottom_toBottomOf="@id/gpIcon"
                app:layout_constraintStart_toEndOf="@id/gpIcon"
                app:layout_constraintEnd_toStartOf="@id/gpClose"/>

            <ImageButton
                android:id="@+id/gpClose"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="@color/text_secondary"
                app:layout_constraintTop_toTopOf="@id/gpIcon"
                app:layout_constraintBottom_toBottomOf="@id/gpIcon"
                app:layout_constraintEnd_toEndOf="parent"/>

            <!-- РАСШИРЕННЫЙ ВИД (Появляется при клике) -->
            <LinearLayout
                android:id="@+id/gpExpandedControls"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:layout_marginTop="16dp"
                app:layout_constraintTop_toBottomOf="@id/gpIcon">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/gpCurrentTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0:00"
                        android:textSize="12sp"
                        android:textColor="@color/text_secondary"/>

                    <SeekBar
                        android:id="@+id/gpSeekBar"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:progressTint="#3390EC"
                        android:thumbTint="#3390EC"/>

                    <TextView
                        android:id="@+id/gpTotalTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0:00"
                        android:textSize="12sp"
                        android:textColor="@color/text_secondary"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginTop="8dp">

                    <ImageButton
                        android:id="@+id/gpDownload"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@android:drawable/stat_sys_download"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        app:tint="@color/text_secondary"/>

                    <!-- Место для кнопок 1.5x скорости в будущем -->
                </LinearLayout>
            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/chatRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        app:layout_constraintTop_toBottomOf="@id/appBarLayout"
        app:layout_constraintBottom_toTopOf="@id/bottomInputContainer"/>

    <!-- ПУСТОЙ ЧАТ -->
    <LinearLayout
        android:id="@+id/emptyChatContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone"
        android:background="@drawable/bg_service_message"
        android:paddingHorizontal="24dp"
        android:paddingVertical="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/ic_profile_placeholder"
            android:layout_marginBottom="12dp"
            app:tint="@color/text_secondary"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Здесь пока нет сообщений"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            android:textSize="16sp"/>

        <TextView
            android:id="@+id/btnSayHello"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="👋 Поздороваться"
            android:textColor="@color/white"
            android:background="@drawable/bg_chat_bubble_me"
            android:backgroundTint="#3390EC"
            android:paddingHorizontal="20dp"
            android:paddingVertical="10dp"
            android:layout_marginTop="16dp"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabScrollDown"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        android:src="@android:drawable/arrow_down_float"
        app:fabSize="mini"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/bottomInputContainer"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- НИЖНЯЯ ПАНЕЛЬ ВВОДА -->
    <LinearLayout
        android:id="@+id/bottomInputContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/primary"
        android:elevation="8dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- ПРЕВЬЮ ФОТО -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/imagePreviewContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="16dp"
            android:paddingTop="8dp"
            android:visibility="gone">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="80dp"
                android:layout_height="80dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent">
                <ImageView
                    android:id="@+id/ivPreviewImage"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop" />
            </com.google.android.material.card.MaterialCardView>

            <ImageButton
                android:id="@+id/btnRemoveImage"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                android:background="@drawable/circle_background"
                android:backgroundTint="#80000000"
                app:tint="@android:color/white"
                android:padding="4dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                android:layout_marginStart="64dp"
                android:layout_marginTop="-4dp"/>
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- ПРЕВЬЮ ОТВЕТА -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/replyPreviewContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            android:background="@color/chat_input_bg"
            android:visibility="gone">

            <View
                android:id="@+id/replyLine"
                android:layout_width="3dp"
                android:layout_height="0dp"
                android:background="#3390EC"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="12dp"
                app:layout_constraintStart_toEndOf="@id/replyLine"
                app:layout_constraintEnd_toStartOf="@id/btnCloseReply"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent">

                <TextView
                    android:id="@+id/tvReplySender"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#3390EC"
                    android:textStyle="bold"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tvReplyText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_secondary"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:textSize="13sp" />
            </LinearLayout>

            <ImageButton
                android:id="@+id/btnCloseReply"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="@color/text_secondary"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"/>
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- КОНТЕЙНЕРЫ ВВОДА (Текст и Запись ГС разделены!) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp"
            android:paddingVertical="8dp"
            android:gravity="bottom"
            android:clipChildren="false"
            android:clipToPadding="false">

            <!-- ЛЕВАЯ ЧАСТЬ: Поле текста ИЛИ Панель записи (переключаются) -->
            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1">

                <!-- 1. ПАНЕЛЬ ВВОДА ТЕКСТА -->
                <LinearLayout
                    android:id="@+id/textInputContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="bottom">

                    <ImageButton
                        android:id="@+id/btnAttach"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_marginEnd="8dp"
                        android:src="@android:drawable/ic_menu_add"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        app:tint="@color/text_secondary" />

                    <EditText
                        android:id="@+id/etMessageInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Сообщение..."
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_secondary"
                        android:background="@drawable/bg_chat_input_modern"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="10dp"
                        android:minHeight="40dp"
                        android:maxLines="5"
                        android:textSize="15sp"
                        android:inputType="textMultiLine|textCapSentences"/>
                </LinearLayout>

                <!-- 2. ПАНЕЛЬ ЗАПИСИ ГС -->
                <LinearLayout
                    android:id="@+id/recordingContainer"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:visibility="gone"
                    android:background="@color/primary">

                    <View
                        android:id="@+id/redDot"
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:background="@drawable/circle_background"
                        android:backgroundTint="#FF3B30"/>

                    <TextView
                        android:id="@+id/tvRecordTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="00:00"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:layout_marginStart="8dp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tvSlideToCancel"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="◀ Отменить"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp"
                        android:gravity="end"
                        android:layout_marginEnd="16dp"/>

                    <TextView
                        android:id="@+id/btnCancelVoiceLock"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="ОТМЕНА"
                        android:textColor="#FF3B30"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:gravity="end"
                        android:layout_marginEnd="16dp"
                        android:visibility="gone"
                        android:paddingVertical="8dp"
                        android:background="?attr/selectableItemBackgroundBorderless"/>
                </LinearLayout>
            </FrameLayout>

            <!-- ПРАВАЯ ЧАСТЬ: Кнопки (Всегда поверх, никогда не перекрываются!) -->
            <FrameLayout
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:clipChildren="false">

                <ImageButton
                    android:id="@+id/btnRecordVoice"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@android:drawable/ic_btn_speak_now"
                    android:background="@drawable/circle_background"
                    android:backgroundTint="#1A3390EC"
                    app:tint="#3390EC" />

                <ImageButton
                    android:id="@+id/btnSend"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@android:drawable/ic_menu_send"
                    android:background="@drawable/circle_background"
                    android:backgroundTint="#3390EC"
                    android:visibility="gone"
                    app:tint="@android:color/white" />
            </FrameLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- ЗАМОК ФИКСАЦИИ (Вынесен отдельно, чтобы не перекрываться) -->
    <LinearLayout
        android:id="@+id/lockOverlay"
        android:layout_width="48dp"
        android:layout_height="120dp"
        android:orientation="vertical"
        android:gravity="top|center_horizontal"
        android:background="@drawable/bg_chat_input_modern"
        android:visibility="gone"
        android:paddingTop="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="40dp">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_lock"
            app:tint="@color/text_secondary"/>
        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_marginTop="12dp"
            android:src="@drawable/ic_arrow_up"
            app:tint="@color/text_secondary"/>
    </LinearLayout>

    <FrameLayout
        android:id="@+id/galleryContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FF000000"
        android:visibility="gone"
        android:elevation="40dp"
        android:alpha="0">

        <!-- Листалка фото -->
        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/galleryViewPager"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <!-- Верхний Тулбар галереи -->
        <LinearLayout
            android:id="@+id/galleryToolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingTop="40dp"
            android:paddingBottom="24dp"
            android:paddingHorizontal="8dp"
            android:background="@drawable/bg_gallery_toolbar"
            android:gravity="center_vertical">

            <ImageButton
                android:id="@+id/btnGalleryClose"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_arrow_back"
                app:tint="@android:color/white" />

            <TextView
                android:id="@+id/tvGalleryCounter"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                android:shadowColor="#80000000"
                android:shadowDx="0"
                android:shadowDy="2"
                android:shadowRadius="4"
                android:text="1 из 5" />

            <ImageButton
                android:id="@+id/btnGalleryMenu"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_download"
                app:tint="@android:color/white" />
        </LinearLayout>
    </FrameLayout>
</androidx.constraintlayout.widget.ConstraintLayout>